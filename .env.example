# Copy to .env and fill in your credentials. Never commit .env.

# CDF target
CDF_CLUSTER=az-eastus-1
CDF_PROJECT=radix-dev
CDF_URL=https://az-eastus-1.cognitedata.com

# OAuth / machine-to-machine (used by Flows CLI and the CDF MCP wrapper)
LOGIN_FLOW=client_credentials
IDP_CLIENT_ID=your-client-id
IDP_CLIENT_SECRET=your-client-secret
IDP_TENANT_ID=your-tenant-id
IDP_TOKEN_URL=https://login.microsoftonline.com/your-tenant-id/oauth2/v2.0/token
IDP_SCOPES=https://az-eastus-1.cognitedata.com/.default
IDP_AUDIENCE=

# Optional MCP overrides (defaults come from scripts/cdf-mcp.config.json)
# CDF_DATA_MODELS=[{"space":"RadixSpace","externalId":"MaterialDOM","version":"v10"}]
# CDF_INSTANCE_SPACES=["RadixSpace","GOA_WORK_MANAGEMENT"]
